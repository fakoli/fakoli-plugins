{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fakoli-plugins.github.io/schemas/marketplace.schema.json",
  "title": "Claude Code Plugin Marketplace",
  "description": "Schema for marketplace.json — based on https://code.claude.com/docs/en/plugin-marketplaces with custom extensions",
  "type": "object",
  "required": ["name", "owner", "plugins"],
  "additionalProperties": true,
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema reference for IDE validation"
    },
    "name": {
      "type": "string",
      "description": "Marketplace identifier"
    },
    "displayName": {
      "type": "string",
      "description": "Human-readable marketplace name (custom extension — not in official spec)"
    },
    "owner": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Owner's name"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "Owner's email"
        },
        "github": {
          "type": "string",
          "description": "Owner's GitHub username (custom extension)"
        }
      },
      "additionalProperties": false
    },
    "metadata": {
      "type": "object",
      "properties": {
        "description": {
          "type": "string",
          "description": "Marketplace description"
        },
        "version": {
          "type": "string",
          "description": "Marketplace version"
        },
        "pluginRoot": {
          "type": "string",
          "description": "Root directory for plugin resolution"
        }
      },
      "additionalProperties": false
    },
    "description": {
      "type": "string",
      "description": "Marketplace description (custom extension — official spec uses metadata.description)"
    },
    "version": {
      "type": "string",
      "description": "Marketplace version (custom extension — official spec uses metadata.version)"
    },
    "repository": {
      "oneOf": [
        { "type": "string", "format": "uri" },
        {
          "type": "object",
          "properties": {
            "type": { "type": "string" },
            "url": { "type": "string", "format": "uri" }
          }
        }
      ],
      "description": "Source code URL (custom extension)"
    },
    "categories": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": "string" }
        }
      },
      "description": "Category definitions (custom extension)"
    },
    "plugins": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "source"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Plugin identifier"
          },
          "source": {
            "oneOf": [
              { "type": "string", "description": "Relative path or URL to plugin" },
              {
                "type": "object",
                "required": ["url"],
                "properties": {
                  "url": { "type": "string" },
                  "branch": { "type": "string" },
                  "path": { "type": "string" }
                }
              }
            ],
            "description": "Plugin source (path or URL)"
          },
          "description": { "type": "string" },
          "version": { "type": "string" },
          "author": {
            "oneOf": [
              { "type": "string" },
              {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "email": { "type": "string" },
                  "url": { "type": "string" }
                }
              }
            ]
          },
          "homepage": { "type": "string" },
          "repository": { "type": "string" },
          "license": { "type": "string" },
          "keywords": { "type": "array", "items": { "type": "string" } },
          "category": { "type": "string" },
          "tags": { "type": "array", "items": { "type": "string" } },
          "strict": { "type": "boolean" }
        },
        "additionalProperties": false
      },
      "description": "List of plugins in this marketplace"
    }
  }
}
