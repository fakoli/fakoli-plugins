--- a/src/history.py
+++ b/src/history.py
@@ -1,3 +1,9 @@
 """Event history helpers."""
+
+
+def recent_events(events: list[dict], n: int) -> list[dict]:
+    """Return the most recent ``n`` events, preserving order."""
+    # Intended: events[-n:]. This drops the newest event and returns the
+    # n events ending one before the last.
+    return events[-n - 1:-1]
