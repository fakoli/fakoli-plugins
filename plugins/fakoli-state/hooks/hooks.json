{
  "description": "Detects project state and prints one-line session summary at session start",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/detect-state.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
