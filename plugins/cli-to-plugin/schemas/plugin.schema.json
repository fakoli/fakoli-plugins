{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fakoli-plugins.github.io/schemas/plugin.schema.json",
  "title": "Claude Code Plugin Manifest",
  "description": "Schema for Claude Code plugin.json manifests — aligned with https://code.claude.com/docs/en/plugins-reference",
  "type": "object",
  "required": ["name"],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "minLength": 2,
      "maxLength": 64,
      "description": "Plugin identifier (lowercase, alphanumeric, hyphens only)"
    },
    "version": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-((?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*)(?:\\.(?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*))*))?(?:\\+([0-9a-zA-Z-]+(?:\\.[0-9a-zA-Z-]+)*))?$",
      "description": "Semantic version (semver 2.0)"
    },
    "description": {
      "type": "string",
      "minLength": 10,
      "maxLength": 500,
      "description": "Brief description of the plugin's purpose"
    },
    "author": {
      "oneOf": [
        {
          "type": "string",
          "description": "Author name or 'Name <email>' format"
        },
        {
          "type": "object",
          "required": ["name"],
          "properties": {
            "name": {
              "type": "string",
              "description": "Author's full name"
            },
            "email": {
              "type": "string",
              "format": "email",
              "description": "Author's email address"
            },
            "url": {
              "type": "string",
              "format": "uri",
              "description": "Author's website or profile URL"
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "license": {
      "type": "string",
      "description": "SPDX license identifier (e.g., MIT, Apache-2.0)"
    },
    "repository": {
      "type": "string",
      "format": "uri",
      "description": "Repository URL (must be string, not object)"
    },
    "homepage": {
      "type": "string",
      "format": "uri",
      "description": "Plugin homepage URL"
    },
    "keywords": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9-]+$"
      },
      "uniqueItems": true,
      "description": "Keywords for search and discovery"
    },
    "commands": {
      "oneOf": [
        { "type": "string" },
        { "type": "array", "items": { "type": "string" } }
      ],
      "description": "Additional command files/directories (auto-discovered from commands/ — only declare for non-standard locations)"
    },
    "agents": {
      "oneOf": [
        { "type": "string" },
        { "type": "array", "items": { "type": "string" } }
      ],
      "description": "Additional agent files (auto-discovered from agents/ — only declare for non-standard locations)"
    },
    "skills": {
      "oneOf": [
        { "type": "string" },
        { "type": "array", "items": { "type": "string" } }
      ],
      "description": "Additional skill directories (auto-discovered from skills/ — only declare for non-standard locations)"
    },
    "hooks": {
      "oneOf": [
        { "type": "string", "description": "Path to hooks.json file" },
        { "type": "array", "items": { "type": "string" }, "description": "Array of paths to hooks config files" },
        { "type": "object", "description": "Inline hooks configuration" }
      ],
      "description": "Hook config path or inline config"
    },
    "mcpServers": {
      "oneOf": [
        { "type": "string", "description": "Path to .mcp.json file" },
        { "type": "array", "items": { "type": "string" }, "description": "Array of paths to MCP config files" },
        { "type": "object", "description": "Inline MCP server configuration" }
      ],
      "description": "MCP server config path or inline config"
    },
    "outputStyles": {
      "oneOf": [
        { "type": "string" },
        { "type": "array", "items": { "type": "string" } }
      ],
      "description": "Additional output style files/directories"
    },
    "lspServers": {
      "oneOf": [
        { "type": "string", "description": "Path to LSP config file" },
        { "type": "array", "items": { "type": "string" }, "description": "Array of paths to LSP config files" },
        { "type": "object", "description": "Inline LSP server configuration" }
      ],
      "description": "LSP config for code intelligence"
    }
  }
}
