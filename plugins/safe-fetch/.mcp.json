{
  "mcpServers": {
    "safe-fetch": {
      "command": "uv",
      "args": ["run", "--directory", "${CLAUDE_PLUGIN_ROOT}", "python", "-m", "safe_fetch"],
      "env": {
        "ALLOWED_DOMAINS": "",
        "BLOCKED_DOMAINS": "",
        "RATE_LIMIT_PER_DOMAIN": "10",
        "RATE_LIMIT_GLOBAL": "60",
        "BRAVE_API_KEY": "",
        "SAFE_FETCH_TIMEOUT": "30",
        "SAFE_FETCH_MAX_BODY": "5242880"
      }
    }
  }
}
